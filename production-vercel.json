{
  "name": "skvchatgb",
  "version": 2,
  "alias": ["skvchatgb.com", "www.skvchatgb.com"],
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://skvchatgb.com"
  }
}